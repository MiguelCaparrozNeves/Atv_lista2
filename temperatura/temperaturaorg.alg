algoritmo "temperatura"
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
//Variaveis
   celsius, final:real
inicio
// Seçăo de Comandos
   escreva("Informe a temperatura em celsius:")
   leia(celsius)


//calculos

          final<- (9*celsius)/5+32

          limpatela

//exibir dados

         escreval("A temperatura em fahrenheit é  : ",final)


fimalgoritmo

